        <Insets bottom="20.0" left="20.0" right="20.0" top="20.0" />
    </padding>
   <children>
      <HBox prefHeight="30.0" prefWidth="558.0">
         <children>
            <TextField prefHeight="26.0" prefWidth="506.0" />
            <Button mnemonicParsing="false" prefHeight="26.0" prefWidth="145.0" text="Hinzufügen" />
         </children>
      </HBox>
      <ListView fx:id="downloadList" prefHeight="200.0" prefWidth="200.0" />
      <HBox prefHeight="28.0" prefWidth="558.0">
         <children>
            <Label prefHeight="28.0" prefWidth="86.0" text="Zielordner" />
            <TextField fx:id="targetTf" prefHeight="26.0" prefWidth="379.0" />
            <Button mnemonicParsing="false" onAction="#onSearch" prefHeight="26.0" prefWidth="94.0" text="Suchen" />
         </children>
      </HBox>
      <Button mnemonicParsing="false" onAction="#onDownload" prefHeight="26.0" prefWidth="326.0" text="Download" />
