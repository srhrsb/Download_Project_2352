<VBox alignment="BOTTOM_CENTER" prefHeight="335.0" prefWidth="598.0" spacing="20.0" xmlns="http://javafx.com/javafx/23.0.1" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.brh.download_project_2352.Controller">
